{
  "name": "claude-code-web-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Web UI for Claude Code CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claude-code-web-ui": "./bin/claude-code-web-ui.mjs"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch packages/server/src --ext ts --exec ts-node --esm packages/server/src/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p packages/server/tsconfig.json",
    "start": "node bin/claude-code-web-ui.mjs start",
    "test": "vitest"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "koa": "^2.15.4",
    "@koa/router": "^15.4.0",
    "@koa/cors": "^5.0.0",
    "@koa/bodyparser": "^5.1.1",
    "koa-static": "^5.0.0",
    "better-sqlite3": "^11.9.1",
    "ws": "^8.18.0",
    "node-pty": "^1.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "cron": "^3.5.0"
  },
  "devDependencies": {
    "vue": "^3.5.13",
    "naive-ui": "^2.40.3",
    "pinia": "^3.0.2",
    "vue-router": "^4.5.0",
    "vue-i18n": "^11.1.3",
    "axios": "^1.9.0",
    "markdown-it": "^14.1.0",
    "highlight.js": "^11.11.1",
    "sass": "^1.87.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "vitest": "^3.1.2",
    "vue-tsc": "^2.2.8",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa__cors": "^5.0.0",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-static": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.0"
  }
}
